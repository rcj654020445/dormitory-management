    "key_code_paths": {
      "allocation_flow": {
        "description": "Student room allocation process - creates allocation, updates student, updates room bed count",
        "steps": [
          {
            "layer": "handler",
            "file": "internal/handler/allocation_handler.go",
            "method": "Create",
            "action": "HTTP handler receives POST /api/v1/allocations"
          },
          {
            "layer": "service",
            "file": "internal/service/allocation_svc.go",
            "method": "CreateAllocation",
            "action": "Validates student exists, room exists, no existing allocation, room has capacity"
          },
          {
            "layer": "repository",
            "file": "internal/repository/allocation_repo.go",
            "method": "Create",
            "action": "INSERT allocation record"
          },
          {
            "layer": "repository",
            "file": "internal/repository/student_repo.go",
            "method": "AllocateRoom",
            "action": "UPDATE students SET room_id = $2"
          },
          {
            "layer": "repository",
            "file": "internal/repository/room_repo.go",
            "method": "UpdateBedCount",
            "action": "UPDATE rooms SET beds_used = beds_used + 1"
          }
        ]
      },
      "batch_allocation_flow": {
        "description": "Batch student allocation for开学 (semester start)",
        "notes": "Currently not implemented as a single endpoint - would iterate through students via ListRooms + CreateAllocation"
      },
      "checkout_flow": {
        "description": "Student checkout/vacate process",
        "steps": [
          {
            "layer": "handler",
            "file": "internal/handler/student_handler.go",
            "method": "Vacate",
            "action": "HTTP handler receives POST /api/v1/students/:id/vacate"
          },
          {
            "layer": "service",
            "file": "internal/service/student_svc.go",
            "method": "VacateStudent",
            "action": "Validates student has room, clears room_id, decrements bed count"
          },
          {
            "layer": "repository",
            "file": "internal/repository/student_repo.go",
            "method": "VacateRoom",
            "action": "UPDATE students SET room_id = NULL"
          },
          {
            "layer": "repository",
            "file": "internal/repository/room_repo.go",
            "method": "UpdateBedCount",
            "action": "UPDATE rooms SET beds_used = beds_used - 1"
          }
        ]
      },
      "repair_status_flow": {
        "description": "Repair request status state machine",
        "states": [
          "pending -> assigned -> repairing -> completed",
          "pending -> cancelled",
          "assigned -> cancelled"
        ],
        "files": [
          "internal/service/repair_svc.go",
          "internal/repository/repair_repo.go"
        ]
      }
